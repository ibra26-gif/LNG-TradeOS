{
  "functions": {
    "api/*.js": {
      "maxDuration": 30,
      "includeFiles": "{data/*.csv,api/private/**}"
    }
  },
  "rewrites": [
    { "source": "/app", "destination": "/api/drive?action=app" },
    { "source": "/logout", "destination": "/api/drive?action=logout" },
    { "source": "/api/agsi", "destination": "/api/gie?src=agsi" },
    { "source": "/api/aggi", "destination": "/api/gie?src=aggi" }
  ],
  "headers": [
    {
      "source": "/data/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ],
  "crons": [
    { "path": "/api/brazil-ons-hydro", "schedule": "5 22 * * *" },
    { "path": "/api/colombia-xm-hydro", "schedule": "10 10 * * *" }
  ]
}
